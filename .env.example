# Runner
# Choose one provider path.
#
# Public OpenAI
OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
#
# Azure OpenAI / Microsoft Foundry via Entra auth (`az login`)
# Set one Azure URL form plus an API version.
# AZURE_OPENAI_ENDPOINT="https://example.openai.azure.com/"
# AZURE_OPENAI_BASE_URL="https://example.cognitiveservices.azure.com/openai"
# AZURE_OPENAI_RESPONSES_URL="https://example.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview"
# AZURE_OPENAI_API_VERSION="2025-04-01-preview"
# OPENAI_API_VERSION="2025-04-01-preview" # Azure API version fallback
# AZURE_OPENAI_SCOPE="https://cognitiveservices.azure.com/.default"
HOST="127.0.0.1"
PORT="4001"
CUA_DEFAULT_MODEL="gpt-5.4"
CUA_RESPONSES_MODE="auto"

# Web
RUNNER_BASE_URL="http://127.0.0.1:4001"
NEXT_PUBLIC_CUA_DEFAULT_MODEL="gpt-5.4"
NEXT_PUBLIC_CUA_DEFAULT_MAX_RESPONSE_TURNS="24"
